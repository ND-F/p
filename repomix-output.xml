            items-center
          "
        >

          <div
            className="
              flex
              items-center

              gap-5
            "
          >

            <div className="shrink-0">

              <img
                src={logo}
                alt={theme.brand.name}
                className="
                  w-[52px]
                  h-[52px]

                  object-contain
